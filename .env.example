# Replace these example paths with absolute paths on your machine, then run:
# source .env.example
export HFIRBGDATA=/absolute/path/to/hfir-gamma-spectra

# Optional when the canonical database is at db/HFIRBG.db:
# export HFIRBG_CALDB=/absolute/path/to/HFIRBG.db

# Optional: several plotting scripts use this as their output root.
export HFIRBG_ANALYSIS=/absolute/path/to/HFIR_BG_Analysis/analysis
