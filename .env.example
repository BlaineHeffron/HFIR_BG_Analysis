# Source this file from the repository root (or copy it to .env first):
# source .env.example
#
# Override any value before sourcing if your data lives elsewhere. BASH_SOURCE
# keeps the defaults portable even when this repository is moved.
_HFIRBG_REPO_ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"

export HFIRBGDATA="${HFIRBGDATA:-${_HFIRBG_REPO_ROOT}/data/HFIRBG_public_data_v1.0.0/spectra}"
export HFIRBG_CALDB="${HFIRBG_CALDB:-${_HFIRBG_REPO_ROOT}/data/HFIRBG_public_data_v1.0.0/HFIRBG.db}"
export HFIRBG_ANALYSIS="${HFIRBG_ANALYSIS:-${_HFIRBG_REPO_ROOT}/analysis}"
export HFIRBG_PAPER_DATA="${HFIRBG_PAPER_DATA:-${_HFIRBG_REPO_ROOT}/data/arxiv_2607.05834/anc}"

# Optional paths used by the unfolding workflow:
# export HFIRBG_UNFOLD_DATA=/path/to/root-histograms
# export P2X_BIN=/path/to/P2x_Analyze
# export HFIRBG_PAPER_FIG_DIR=/path/to/paper/figures/pdf

unset _HFIRBG_REPO_ROOT
